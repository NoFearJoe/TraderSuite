<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- CloudKit delivers silent pushes to drive sync; without this background
	     mode CloudKit traps at launch ("BUG IN CLIENT OF CLOUDKIT: …remote-notification…").
	     All other Info.plist keys are still generated (GENERATE_INFOPLIST_FILE=YES)
	     and merged into this partial plist. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
